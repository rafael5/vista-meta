# vista-meta .gitignore
# Spec: docs/vista-meta-spec-v0.4.md § 3

# Runtime config (contains Tailscale IP)
.env

# Bake raw output — regenerated, large
vista/export/**/raw/

# Bake logs
vista/export/logs/

# Host-side routine snapshot — synced from image via `make sync-routines` (ADR-045)
vista/vista-m-host/

# Named-volume snapshots
snapshots/

# Host Python venv
host/.venv/

# YottaDB temp/journal files
*.o
*.mjo

# OS artifacts
.DS_Store
Thumbs.db
__pycache__/
*.egg-info/
