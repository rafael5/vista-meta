# VistALink — port 8001
# M-side listener for VistALink J2SE connections.
# ydb-run wrapper sources YDB env before exec'ing mumps.

service vlink
{
    type        = UNLISTED
    port        = 8001
    socket_type = stream
    protocol    = tcp
    wait        = no
    user        = vehu
    server      = /usr/local/bin/ydb-run
    server_args = -run XOBVTCP
}
